# Example production env — copy to /opt/carsaction/.env on the VPS.
# NEVER commit real secrets.
# First smoke can use Stripe test keys (sk_test_...); swap to live when ready.

# --- Docker Compose DB (used by docker-compose.prod.yml) ---
POSTGRES_USER=carsaction
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD
POSTGRES_DB=carsaction

# --- App ---
DATABASE_URL=postgresql://carsaction:CHANGE_ME_LONG_RANDOM_PASSWORD@db:5432/carsaction?schema=public
AUTH_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32
AUTH_URL=https://carsaction.sg
AUTH_TRUST_HOST=true
NEXT_PUBLIC_APP_URL=https://carsaction.sg

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe LIVE keys from the client's Singapore account
# 1) Dashboard (Live mode) -> Developers -> API keys -> Secret key (sk_live_...)
# 2) Create LIVE Gold/Platinum recurring SGD prices (or run setup:stripe with live key)
# 3) Developers -> Webhooks -> endpoint https://carsaction.sg/api/stripe/webhook -> Signing secret
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_GOLD=price_...
STRIPE_PRICE_PLATINUM=price_...

RESEND_API_KEY=
