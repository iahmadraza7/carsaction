# CARSaction environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
# Matches docker-compose.yml (Postgres 16 on host port 5433).
DATABASE_URL="postgresql://carsaction:carsaction@localhost:5433/carsaction?schema=public"

# --- Auth.js (NextAuth v5) ---
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL="http://localhost:3000"

# Google OAuth (optional in dev, required for Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe ---
# Client's Singapore Stripe account.
# Local/dev: sk_test_... + test price IDs + Stripe CLI webhook secret
# Production: sk_live_... + LIVE price IDs + Dashboard webhook signing secret (whsec_...)
# Never commit real keys. Put live/test keys only in VPS /opt/carsaction/.env
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_GOLD=          # Stripe Price ID for Gold tier (must match mode: test vs live)
STRIPE_PRICE_PLATINUM=      # Stripe Price ID for Platinum tier

# --- Email (Resend) ---
RESEND_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set true in production behind Nginx / Docker so Auth.js trusts X-Forwarded-Host
AUTH_TRUST_HOST="false"
